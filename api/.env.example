# ─── DATABASE ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/menupanda"
DATABASE_URL_TEST="postgresql://postgres:postgres@localhost:5432/menupanda_test"

# ─── REDIS ────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── AUTH ─────────────────────────────────────────────────────────────────────
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-in-production"
# OWNER/ADMIN access: 15m, refresh: 7d
# MOTOBOY access: 8h, refresh: 7d
# CLIENT magic link: 24h

# ─── OAUTH PROVIDERS ──────────────────────────────────────────────────────────
# v2.5+: nomenclatura padronizada `*_APP_ID/SECRET` + flag `*_APP_ENABLE`.
# Provider só é registrado em runtime se a flag estiver `'true'` E as credenciais não vazias.
# Callback URL é derivado dinamicamente do host do request (ver auth.routes.ts).
# Registre no Google Console e Facebook App: {host}/api/v1/auth/{provider}/callback.

# Google OAuth (v2.5+)
GOOGLE_APP_ID="your-google-client-id"
GOOGLE_APP_SECRET="your-google-client-secret"
GOOGLE_APP_ENABLE="false"

# Facebook OAuth (v2.5+)
FACEBOOK_APP_ID="your-facebook-app-id"
FACEBOOK_APP_SECRET="your-facebook-app-secret"
FACEBOOK_APP_ENABLE="false"

# ─── STRIPE ───────────────────────────────────────────────────────────────────
# Prices devem ter `recurring.trial_period_days=7` configurado no dashboard Stripe.
# Dessa forma o trial é herdado automaticamente por toda subscription criada a partir deles.
# Para testar webhook localmente: `stripe listen --forward-to localhost:3001/api/v1/webhooks/stripe`
STRIPE_SECRET_KEY="sk_test_your-stripe-secret-key"
STRIPE_WEBHOOK_SECRET="whsec_your-stripe-webhook-secret"
STRIPE_PROFESSIONAL_PRICE_ID="price_your-professional-price-id"
STRIPE_PREMIUM_PRICE_ID="price_your-premium-price-id"
# Grace period (dias) após `invoice.payment_failed` antes da suspensão automática da loja
# (enforced pelo cron trial-suspension.job). Default: 1 dia.
STRIPE_GRACE_PERIOD_DAYS=1

# ─── CLOUDINARY ───────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ─── RUNPOD (IA - Plano Premium) ──────────────────────────────────────────────
RUNPOD_API_KEY="your-runpod-api-key"
RUNPOD_ENDPOINT_ID="your-runpod-endpoint-id"

# ─── SMTP (E-MAIL TRANSACIONAL) ───────────────────────────────────────────────
# Templates HTML editáveis em: api/src/shared/email/templates/*.html
#
# DEV (MailHog/Mailpit local):
#   SMTP_HOST=localhost  SMTP_PORT=1025  (sem auth)
#
# PROD (Gmail SMTP — usar App Password, NÃO a senha da conta):
#   1. Habilite 2FA em myaccount.google.com → Security → 2-Step Verification
#   2. Gere App Password em myaccount.google.com → Security → App passwords
#   3. Use abaixo:
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="xxxx xxxx xxxx xxxx"
SMTP_FROM="Menu Panda <your-email@gmail.com>"

# ─── APP ──────────────────────────────────────────────────────────────────────
NODE_ENV="development"
PORT=3001
API_URL="http://localhost:3001"
WEB_URL="http://localhost:5173"
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:3000"

# Domínio raiz do produto — usado pra gerar URLs públicas das lojas
# (`{slug}.${PUBLIC_ROOT_DOMAIN}`), tenant routing por subdomínio, fallback de CORS,
# e fallback dos emails (`noreply@`, `contato@`). Sempre que esta env muda, o sistema
# inteiro passa a usar o novo domínio sem precisar recompilar.
#
# Dev local com dnsmasq:    cardapio.test
# Produção:                  menupanda.com.br
PUBLIC_ROOT_DOMAIN="menupanda.com.br"

# Email de suporte exibido em templates (ex: trial-suspended). Default: contato@${PUBLIC_ROOT_DOMAIN}
SUPPORT_EMAIL="contato@menupanda.com.br"

# ─── GEOCODING ────────────────────────────────────────────────────────────────
# Usado no checkout público para converter endereço do cliente → { lat, lng }.
# Depois, o backend calcula a taxa de entrega via Haversine contra Store.lat/lng.
#
# Provider padrão: Nominatim (OpenStreetMap). Grátis, sem token. Exige User-Agent
# identificando a app (política OSM). Rate-limit: 1 req/s. Cache Redis 7 dias
# por endereço normalizado evita a maioria dos hits.
#
# Pra trocar por Google/Mapbox no futuro, basta implementar a interface em
# geocoding.service.ts e mudar GEOCODING_PROVIDER.
GEOCODING_PROVIDER="nominatim"
NOMINATIM_BASE_URL="https://nominatim.openstreetmap.org"
NOMINATIM_USER_AGENT="MenuPanda/1.0 (wendellalonso2013@gmail.com)"

# ─── LOCAL NETWORK (dnsmasq) ─────────────────────────────────────────────────
# LAN IP da máquina dev (auto-detectado por infra/scripts/setup-dev.sh)
# Usado pelo dnsmasq para resolver *.cardapio.test na rede local
LAN_IP=192.168.0.X
