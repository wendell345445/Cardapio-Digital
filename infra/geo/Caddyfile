# ─── Caddy — reverse proxy da stack geo (mTLS) ───────────────────────────
# Duas camadas de autenticação server-to-server:
#
#  1. mTLS — cert de CLIENTE assinado pela nossa CA privada (certs/ca.crt).
#     Modo `request`: cert pedido no handshake mas opcional no TLS; a exigência
#     é validada pelo matcher @nocert abaixo (sem cert → 403).
#  2. X-API-Key — segunda camada, defense-in-depth.
#
# Usamos `route` (não `handle`) porque route PRESERVA A ORDEM das diretivas —
# essencial pra rodar as checagens de auth ANTES dos reverse_proxy.
#
# A tela /teste antiga foi REMOVIDA no Bloco C. Toda comunicação com o geo
# agora é server-to-server (api Railway via mTLS).

{$GEO_DOMAIN} {
	tls {
		client_auth {
			mode request
			trust_pool file /etc/caddy/certs/ca.crt
		}
	}

	route {
		# Healthcheck público (sem auth, sem mTLS — pra monitoring externo).
		handle /healthz {
			respond "ok" 200
		}

		# PRODUÇÃO — exige cert de cliente válido + API key.
		# Sem cert (não apresentado / não assinado pela CA) → 403.
		@nocert expression `{http.request.tls.client.certificate_der_base64} == ""`
		respond @nocert "client certificate required" 403

		# Sem a API key correta → 403.
		@noauth not header X-Api-Key {$GEO_API_KEY}
		respond @noauth "Forbidden" 403

		# Autenticado: repassa pros serviços.
		handle_path /photon/* {
			reverse_proxy photon:2322
		}
		handle_path /nominatim/* {
			reverse_proxy nominatim:8080
		}
		handle_path /osrm/* {
			reverse_proxy osrm:5000
		}
	}

	header {
		X-Content-Type-Options nosniff
		Referrer-Policy no-referrer
	}
}
