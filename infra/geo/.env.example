# Copie para .env e preencha. NÃO commitar o .env real.
#
#   cp .env.example .env && nano .env

# Domínio do endpoint geo (precisa de DNS A apontando pra IP da VM)
GEO_DOMAIN=geo.menupanda.com.br

# Chave compartilhada entre esta stack e a api Railway (header X-API-Key).
# Gere uma forte:  openssl rand -hex 32
GEO_API_KEY=troque-por-uma-chave-aleatoria-forte

# Senha interna do Postgres do Nominatim (qualquer string forte).
NOMINATIM_PASSWORD=troque-tambem
