# ─── Whatsbot AI — config da VM ───────────────────────────────────────────
# Copie pra .env e ajuste. NUNCA commite .env real (gitignore cobre).

# Domínio público (registro A apontando pra IP estático da VM)
WHATSBOT_DOMAIN=whatsbot.menupanda.com.br

# Chave de API (defense-in-depth com o mTLS). Gere: openssl rand -hex 32
WHATSBOT_API_KEY=

# Postgres local (interno na VM, não exposto fora do compose)
POSTGRES_PASSWORD=

# Modelos Ollama
OLLAMA_CHAT_MODEL=llama3:8b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_NUM_PARALLEL=2

# RAG
RAG_TOP_K=5
RECENT_MSGS=6
PROFILE_REFRESH_EVERY=20
MEMORY_RETENTION_DAYS=365
