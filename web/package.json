{
  "name": "@super-cardapio/web",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "start": "serve dist -s -l ${PORT:-8080}",
    "preview": "vite preview",
