# ─── PUBLIC DOMAIN ────────────────────────────────────────────────────────────
# Domínio raiz do produto — usado por useStoreSlug.ts pra distinguir hostname raiz
# (sem tenant) de subdomínio de loja ({slug}.${VITE_PUBLIC_ROOT_DOMAIN}). Precisa
# bater com `PUBLIC_ROOT_DOMAIN` do api/.env.
#
# Dev local com dnsmasq:    cardapio.test
# Produção:                  menupanda.com.br
VITE_PUBLIC_ROOT_DOMAIN="menupanda.com.br"
